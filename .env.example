# Parley env template. Copy to .env and fill in real values.
#   copy .env.example .env   (Windows)
# .env is gitignored — never commit real secrets.
# Vars already set in the real shell environment win over .env (no override).

# --- Web API (required) ---
# Bearer token for ALL data routes. Pick any non-empty secret.
PARLEY_TOKEN=changeme

# Server bind (run.bat reads these). Keep host on loopback.
PARLEY_HOST=127.0.0.1
PARLEY_PORT=8800

# Optional: override registry/data home (defaults to ~/.parley)
# PARLEY_HOME=D:\Projects\Parley\data

# --- Telegram notifier (optional; leave blank to disable push) ---
# Bot token from @BotFather.
PARLEY_TG_TOKEN=
# Supergroup id (the -100... numeric form). Bot must be admin with Manage Topics.
PARLEY_TG_GROUP_ID=
# Telegram user ids allowed to issue /stop /pause /continue /steer.
# Comma- or space-separated. EMPTY = push-only (no one can control). Fail-closed.
PARLEY_TG_ALLOWED_USER_IDS=
# Default push level when a project hasn't overridden it: milestone | escalate | verbose
PARLEY_TG_LEVEL=milestone
